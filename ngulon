-- KEY LOGIC  —  validation via Junkie.check_key (Arqel method)
-- ════════════════════════════════════════════════════════════════════════════
local function SetStatus(message, statusType)
    local color = statusType=="success" and Themes.Success or statusType=="error" and Themes.Error or statusType=="warning" and Themes.Warning or Themes.Idle
    Tween(StatusDot,   {BackgroundColor3=color}, 0.12)
    Tween(StatusLabel, {TextColor3=color},       0.12)
    StatusLabel.Text = message
end

local function ShakeInput()
    local orig=InputCard.Position; local ox=orig.X.Offset
    for _,offset in ipairs({5,-5,3,-3,1,-1,0}) do
        InputCard.Position=UDim2.new(orig.X.Scale, ox+offset, orig.Y.Scale, orig.Y.Offset); task.wait(0.025)
    end; InputCard.Position=orig
end

local processing = false

-- Resolves a Junkie result table → {valid, errorMessage}
local function ResolveJunkieResult(result)
    if not result then return false, "Network error" end
    if type(result) == "table" then
        local valid = result.valid == true
        if valid then return true, nil end
        local errCode = result.error or result.message or "Unknown"
        local msg = ERROR_MESSAGES[errCode] or result.message or errCode
        return false, msg
    end
    if type(result) == "boolean" then return result, result and nil or "Invalid key" end
    return false, "Invalid key"
end

local function TryValidate(key)
    if not key or #key==0 then SetStatus("Enter a key first","warning"); ShakeInput(); return end
    if processing then return end
    if TouchCooldown("_MOONHUB_KS_LOCK", 0.8) then return end

    -- Wait for SDK if still loading
    if not Junkie then
        SetStatus("Loading SDK... try again","warning"); ShakeInput()
        if getgenv then getgenv()._MOONHUB_KS_LOCK=nil end; return
    end

    processing=true
    RedeemLabel.Text="Checking..."; RedeemButton.Active=false
    Tween(RedeemButton,{BackgroundColor3=Color3.fromRGB(24,24,30)},0.15)
    Tween(InputStroke,{Color=Themes.Border, Transparency=0},0.15)
    SetStatus("Verifying key...","warning")

    task.spawn(function()
        local function resetRedeem()
            RedeemLabel.Text="Redeem Key"; RedeemLabel.TextColor3=Themes.TextDim
            RedeemButton.Active=true
            Tween(RedeemButton,{BackgroundColor3=Themes.Pending},0.15)
            if getgenv then getgenv()._MOONHUB_KS_LOCK=nil end
            processing=false
        end

        local ok, result = pcall(function() return Junkie.check_key(key) end)
        if not ok then
            SetStatus("Network error – try again","error")
            Tween(InputStroke,{Color=Themes.Error, Transparency=0},0.15); ShakeInput()
            task.delay(0.5, function() Tween(InputStroke,{Color=Themes.Border, Transparency=0},0.3) end)
            resetRedeem(); return
        end

        local valid, errMsg = ResolveJunkieResult(result)

        if not valid then
            -- Special: hardware banned → kick
            if result and (result.error == "HWID_BANNED") then
                SetStatus("Hardware banned","error")
                Tween(InputStroke,{Color=Themes.Error, Transparency=0},0.15)
                task.delay(2, function() pcall(function() LocalPlayer:Kick("Hardware banned") end) end)
                resetRedeem(); return
            end
            SetStatus(errMsg or "Invalid key","error")
            Tween(InputStroke,{Color=Themes.Error, Transparency=0},0.15); ShakeInput()
            task.delay(0.5, function() Tween(InputStroke,{Color=Themes.Border, Transparency=0},0.3) end)
            resetRedeem(); return
        end

        -- ✓ Key valid
        SaveKey(key); getgenv().SCRIPT_KEY=key
        SetStatus("Key Accepted","success")
        Tween(InputCard,    {BackgroundColor3=Color3.fromRGB(10,28,18)},0.2)
        Tween(InputStroke,  {Color=Themes.Success, Transparency=0},     0.2)
        Tween(RedeemButton, {BackgroundColor3=Color3.fromRGB(16,46,28)},0.2)
        RedeemLabel.Text="Redeemed"; RedeemLabel.TextColor3=Themes.Success
        if getgenv then getgenv()._MOONHUB_KS_LOCK=nil end
        processing=false
        if Options.AutoClose then task.delay(1.25, function() CloseDoorAnimation() end) end
    end)
end

