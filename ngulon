    local CameraInput = require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("CameraModule"):WaitForChild("CameraInput"))
    local uiDragging=false; local activeDragInput=nil; local dragStart=nil; local startPos=nil; local hasMoved=false
    local function isClickInput(input) return input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch end
    local function clampWindow()
        local vp=workspace.CurrentCamera.ViewportSize; local pos=Window.Position
        return UDim2.new(0, math.clamp(pos.X.Offset,0,vp.X-WINDOW_WIDTH), 0, math.clamp(pos.Y.Offset,0,vp.Y-WINDOW_HEIGHT))
    end
    local function startDrag(input)
        if not isClickInput(input) or uiDragging then return end
        uiDragging=true; activeDragInput=input; dragStart=input.Position; startPos=Window.Position; hasMoved=false
        pcall(function() CameraInput.setInputEnabled(false) end)
    end
    Header.InputBegan:Connect(startDrag); Window.InputBegan:Connect(startDrag)
    UserInputService.InputChanged:Connect(function(input)
        if not uiDragging then return end
        if IS_MOBILE then if activeDragInput~=input or input.UserInputType~=Enum.UserInputType.Touch then return end
        else if input.UserInputType~=Enum.UserInputType.MouseMovement then return end end
        local delta=input.Position-dragStart
        if math.abs(delta.X)>4 or math.abs(delta.Y)>4 then hasMoved=true end
        Window.Position=UDim2.new(0, startPos.X.Offset+delta.X, 0, startPos.Y.Offset+delta.Y)
    end)
    UserInputService.InputEnded:Connect(function(input)
        if not uiDragging then return end
        if IS_MOBILE then if activeDragInput~=input or input.UserInputType~=Enum.UserInputType.Touch then return end
        else if input.UserInputType~=Enum.UserInputType.MouseButton1 then return end end
        uiDragging=false; activeDragInput=nil
        pcall(function() CameraInput.setInputEnabled(true) end)
        task.spawn(function() task.wait(0.05); hasMoved=false end)
        Tween(Window, {Position=clampWindow()}, 0.2, Enum.EasingStyle.Quint)
    end)
end

